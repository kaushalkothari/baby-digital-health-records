# Copy to `.env` and fill in. Only `VITE_*` variables are exposed to the client bundle.

# App metadata (injected into index.html at build time)
VITE_APP_TITLE=BabyBloom
VITE_APP_DESCRIPTION=Nurturing every little milestone
VITE_APP_AUTHOR=

# Public site URL (no trailing slash) — canonical / Open Graph URL
VITE_SITE_URL=http://localhost:8080

# Absolute URL for og:image and twitter:image (must be absolute for most crawlers)
VITE_OG_IMAGE_URL=http://localhost:8080/placeholder.svg

VITE_TWITTER_SITE=

# Google Fonts stylesheet URL (loaded in index.html)
VITE_GOOGLE_FONTS_CSS_URL=https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Quicksand:wght@400;500;600;700&display=swap

# Sentry (client-side error tracking)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# Optional: fraction of sessions to record for Session Replay (0.0–1.0)
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1.0
# Performance monitoring sample rate in production (0.0–1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE_PROD=0.2

# When you add a backend (e.g. Supabase), use anon key + URL here — never commit real secrets to git
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
